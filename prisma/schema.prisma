generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "rhel-openssl-1.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id            String         @id @default(cuid())
  email         String         @unique
  password      String
  name          String?
  avatar        String?
  cover         String?
  bio           String?
  location      String?
  website       String?
  role          String         @default("USER")
  banned        Boolean        @default(false)
  inn           String?
  phone         String?
  emailVerified Boolean        @default(false)
  verificationToken String?
  emailChangeCode String?
  socialLinks   String         @default("{}")
  interests     String         @default("[]") // JSON array: ["kitchens", "wardrobes", "minimalism"]
  profileViews  Int            @default(0)
  profileBanners String        @default("[]") // JSON array: [{id, position, imageUrl, title, subtitle, linkUrl, buttonText, active}]
  profileTheme  String         @default("{}") // JSON: {type: "image"|"gradient"|"preset", value: string}
  lastActiveAt  DateTime?      // Для отслеживания онлайн-статуса
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt

  downloads     Download[]
  ratings       Rating[]
  posts         Post[]
  portfolio     PortfolioItem[]
  postLikes     PostLike[]
  comments      Comment[]
  company       Company?       @relation(fields: [companyId], references: [id])
  companyId     String?
  specialist    Specialist?    @relation(fields: [specialistId], references: [id])
  specialistId  String?   @unique
  manufacturer  Manufacturer?  @relation(fields: [manufacturerId], references: [id])
  manufacturerId String?
  supplier      Supplier?      @relation(fields: [supplierId], references: [id])
  supplierId    String?
  following     Follow[]       @relation("Following")
  followers     Follow[]       @relation("Followers")
  notifications Notification[]
  sentNotifications Notification[] @relation("NotificationFrom")
  favorites     Favorite[]
  conversations ConversationParticipant[]
  sentMessages  Message[]
  ownedGroups   Group[]
  groupMemberships GroupMember[]
  groupPosts    GroupPost[]
  bookmarks     Bookmark[]
  reposts       Repost[]
  organizedEvents Event[]
  eventParticipations EventParticipant[]
  productReviews ProductReview[]
  promotions     Promotion[]
  banners        Banner[]
  subscriptions  Subscription[]
  reviewsWritten  UserProfileReview[] @relation("ReviewsWritten")
  reviewsReceived UserProfileReview[] @relation("ReviewsReceived")
  pushSubscriptions PushSubscription[]
  feedback        Feedback[]
  activityLogs    ActivityLog[]
  documents       Document[]
  referralCode    String?   @unique
  referredBy      Referral? @relation("ReferredUser")
  referralsMade   Referral[] @relation("ReferrerUser")
  promoParticipations PromoParticipation[]
}

model Referral {
  id          String   @id @default(cuid())
  referrerId  String
  referredId  String   @unique
  createdAt   DateTime @default(now())

  referrer    User     @relation("ReferrerUser", fields: [referrerId], references: [id])
  referred    User     @relation("ReferredUser", fields: [referredId], references: [id])

  @@index([referrerId])
}

model PromoParticipation {
  id          String   @id @default(cuid())
  promoKey    String
  status      String   @default("pending") // pending | approved | rejected | completed
  proofUrl    String?
  proofImages String   @default("[]")
  note        String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId      String

  @@unique([userId, promoKey])
  @@index([promoKey, status])
}

model Specialist {
  id            String          @id @default(cuid())
  type          String
  description   String?
  experience    Int?
  portfolio     String?
  rating        Float           @default(0)
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt

  user          User?
  ratings       Rating[]
}

model Company {
  id            String          @id @default(cuid())
  name          String
  description   String?
  logo          String?
  website       String?
  phone         String?
  email         String?
  address       String?
  isVerified    Boolean         @default(false)
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt

  users         User[]
  products      Product[]
  posts         Post[]
}

model Supplier {
  id            String          @id @default(cuid())
  companyName   String
  description   String?
  logo          String?
  website       String?
  phone         String?
  email         String?
  categories    String          @default("[]")
  isVerified    Boolean         @default(false)
  notifyNewCompanies Boolean   @default(false)
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt

  products      Product[]
  users         User[]
  posts         Post[]
}

model Product {
  id            String          @id @default(cuid())
  name          String
  description   String?
  price         Float?
  images        String          @default("[]")
  category      String
  brand         String?
  specs         String          @default("[]")
  views         Int             @default(0)
  isPublished   Boolean         @default(true)
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt

  company       Company?        @relation(fields: [companyId], references: [id])
  companyId     String?
  supplier      Supplier?       @relation(fields: [supplierId], references: [id])
  supplierId    String?
  manufacturer  Manufacturer?   @relation(fields: [manufacturerId], references: [id])
  manufacturerId String?
  reviews       ProductReview[]
}

model ProductReview {
  id            String          @id @default(cuid())
  score         Int
  comment       String?
  createdAt     DateTime        @default(now())

  user          User            @relation(fields: [userId], references: [id])
  userId        String
  product       Product         @relation(fields: [productId], references: [id], onDelete: Cascade)
  productId     String

  @@unique([userId, productId])
  @@index([productId])
}

model UserProfileReview {
  id            String    @id @default(cuid())
  score         Int
  comment       String?
  createdAt     DateTime  @default(now())
  status        String    @default("pending")
  disputeText   String?
  disputeImages String    @default("[]")
  disputedAt    DateTime?
  respondedAt   DateTime?
  expiresAt     DateTime?

  reviewer     User     @relation("ReviewsWritten", fields: [reviewerId], references: [id])
  reviewerId   String
  target       User     @relation("ReviewsReceived", fields: [targetUserId], references: [id])
  targetUserId String

  @@index([targetUserId])
  @@index([reviewerId])
  @@index([status])
}

model Image {
  id            String          @id @default(cuid())
  title         String
  description   String?
  url           String
  thumbnail     String?
  style         String?
  category      String?
  tags          String          @default("[]")
  downloads     Int             @default(0)
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt

  downloadsList Download[]

  @@index([downloads])
}

model Download {
  id            String          @id @default(cuid())
  createdAt     DateTime        @default(now())

  user          User            @relation(fields: [userId], references: [id])
  userId        String
  image         Image           @relation(fields: [imageId], references: [id])
  imageId       String

  @@index([userId])
  @@index([imageId])
}

model Document {
  id            String          @id @default(cuid())
  title         String
  description   String?
  fileUrl       String
  fileName      String?
  fileSize      Int?
  category      String
  fileType      String
  downloads     Int             @default(0)
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt

  user          User?           @relation(fields: [userId], references: [id])
  userId        String?

  @@index([userId])
}

model Reference {
  id            String          @id @default(cuid())
  title         String
  description   String?
  content       String
  category      String
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt
}

model Manufacturer {
  id            String          @id @default(cuid())
  name          String
  description   String?
  logo          String?
  website       String?
  phone         String?
  email         String?
  address       String?
  capabilities  String          @default("[]")
  geometry      String?
  isVerified    Boolean         @default(false)
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt

  users         User[]
  products      Product[]
}

model Rating {
  id            String          @id @default(cuid())
  score         Int
  comment       String?
  createdAt     DateTime        @default(now())

  user          User            @relation(fields: [userId], references: [id])
  userId        String
  specialist    Specialist      @relation(fields: [specialistId], references: [id])
  specialistId  String

  @@unique([userId, specialistId])
  @@index([specialistId])
}

model Post {
  id            String          @id @default(cuid())
  title         String
  content       String
  category      String          @default("news")
  images        String          @default("[]")
  tags          String          @default("[]")
  likes         Int             @default(0)
  views         Int             @default(0)
  isPublished   Boolean         @default(true)
  isProfilePromo Boolean        @default(false)
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt

  author        User            @relation(fields: [authorId], references: [id])
  authorId      String
  company       Company?        @relation(fields: [companyId], references: [id])
  companyId     String?
  supplier      Supplier?       @relation(fields: [supplierId], references: [id])
  supplierId    String?
  comments      Comment[]
  likesList     PostLike[]
  reposts       Repost[]
  promotions    Promotion[]

  @@index([authorId])
  @@index([isPublished, createdAt])
}

model PortfolioItem {
  id            String          @id @default(cuid())
  title         String
  description   String?
  imageUrl      String?
  images        String          @default("[]")
  videos        String          @default("[]") // JSON array of video URLs
  documents     String          @default("[]") // JSON array: [{url, name, type, size}]
  category      String?
  tags          String          @default("[]")
  isPublished   Boolean         @default(true)
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt

  user          User            @relation(fields: [userId], references: [id])
  userId        String

  @@index([userId])
}

model Comment {
  id            String          @id @default(cuid())
  content       String
  createdAt     DateTime        @default(now())

  author        User            @relation(fields: [authorId], references: [id])
  authorId      String
  post          Post            @relation(fields: [postId], references: [id], onDelete: Cascade)
  postId        String

  @@index([postId])
}

model PostLike {
  id            String          @id @default(cuid())
  createdAt     DateTime        @default(now())

  user          User            @relation(fields: [userId], references: [id])
  userId        String
  post          Post            @relation(fields: [postId], references: [id], onDelete: Cascade)
  postId        String

  @@unique([userId, postId])
  @@index([postId])
}

model Follow {
  id            String          @id @default(cuid())
  createdAt     DateTime        @default(now())

  follower      User            @relation("Following", fields: [followerId], references: [id])
  followerId    String
  following     User            @relation("Followers", fields: [followingId], references: [id])
  followingId   String

  @@unique([followerId, followingId])
}

model Notification {
  id            String         @id @default(cuid())
  type          String
  message       String
  read          Boolean        @default(false)
  link          String?
  createdAt     DateTime       @default(now())

  user          User           @relation(fields: [userId], references: [id])
  userId        String
  fromUser      User?          @relation("NotificationFrom", fields: [fromUserId], references: [id])
  fromUserId    String?
  postId        String?

  @@index([userId])
  @@index([userId, read])
}

model Favorite {
  id            String         @id @default(cuid())
  itemType      String
  itemId        String
  createdAt     DateTime       @default(now())

  user          User           @relation(fields: [userId], references: [id])
  userId        String

  @@unique([userId, itemType, itemId])
}

model Conversation {
  id            String         @id @default(cuid())
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt

  participants  ConversationParticipant[]
  messages      Message[]
}

model ConversationParticipant {
  id            String         @id @default(cuid())
  createdAt     DateTime       @default(now())

  user          User           @relation(fields: [userId], references: [id])
  userId        String
  conversation  Conversation   @relation(fields: [conversationId], references: [id])
  conversationId String
  lastReadAt    DateTime?

  @@unique([userId, conversationId])
}

model Message {
  id            String         @id @default(cuid())
  content       String
  attachments   String         @default("[]") // JSON массив URL файлов
  reactions     String         @default("{}") // JSON {emoji: [userId, ...]}
  replyToId     String?        // ID сообщения на которое отвечаем
  createdAt     DateTime       @default(now())

  author        User           @relation(fields: [authorId], references: [id])
  authorId      String
  conversation  Conversation   @relation(fields: [conversationId], references: [id])
  conversationId String
  replyTo       Message?       @relation("MessageReplies", fields: [replyToId], references: [id])
  replies       Message[]      @relation("MessageReplies")

  @@index([conversationId])
  @@index([authorId])
  @@index([createdAt])
}

model Group {
  id            String         @id @default(cuid())
  name          String
  description   String?
  coverImage    String?
  type          String         @default("public")
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt

  owner         User           @relation(fields: [ownerId], references: [id])
  ownerId       String
  members       GroupMember[]
  posts         GroupPost[]
}

model GroupMember {
  id            String         @id @default(cuid())
  role          String         @default("member")
  createdAt     DateTime       @default(now())

  user          User           @relation(fields: [userId], references: [id])
  userId        String
  group         Group          @relation(fields: [groupId], references: [id], onDelete: Cascade)
  groupId       String

  @@unique([userId, groupId])
}

model GroupPost {
  id            String         @id @default(cuid())
  content       String
  images        String         @default("[]")
  createdAt     DateTime       @default(now())

  author        User           @relation(fields: [authorId], references: [id])
  authorId      String
  group         Group          @relation(fields: [groupId], references: [id], onDelete: Cascade)
  groupId       String

  @@index([groupId])
}

model Bookmark {
  id            String         @id @default(cuid())
  name          String
  createdAt     DateTime       @default(now())

  user          User           @relation(fields: [userId], references: [id])
  userId        String
  items         BookmarkItem[]
}

model BookmarkItem {
  id            String         @id @default(cuid())
  itemType      String
  itemId        String
  createdAt     DateTime       @default(now())

  bookmark      Bookmark       @relation(fields: [bookmarkId], references: [id], onDelete: Cascade)
  bookmarkId    String

  @@unique([bookmarkId, itemType, itemId])
}

model Repost {
  id            String         @id @default(cuid())
  comment       String?
  createdAt     DateTime       @default(now())

  user          User           @relation(fields: [userId], references: [id])
  userId        String
  post          Post           @relation(fields: [postId], references: [id], onDelete: Cascade)
  postId        String

  @@unique([userId, postId])
}

model Event {
  id            String         @id @default(cuid())
  title         String
  description   String?
  coverImage    String?
  location      String?
  startDate     DateTime
  endDate       DateTime?
  type          String         @default("offline")
  maxParticipants Int?
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt

  organizer     User           @relation(fields: [organizerId], references: [id])
  organizerId   String
  participants  EventParticipant[]
}

model EventParticipant {
  id            String         @id @default(cuid())
  status        String         @default("going")
  createdAt     DateTime       @default(now())

  user          User           @relation(fields: [userId], references: [id])
  userId        String
  event         Event          @relation(fields: [eventId], references: [id], onDelete: Cascade)
  eventId       String

  @@unique([userId, eventId])
  @@index([eventId])
}

model PasswordResetToken {
  id            String         @id @default(cuid())
  token         String         @unique
  userId        String
  expiresAt     DateTime
  used          Boolean        @default(false)
  createdAt     DateTime       @default(now())

  @@index([token])
  @@index([userId])
}

model Promotion {
  id        String   @id @default(cuid())
  status    String   @default("pending") // pending | active | expired
  startDate DateTime @default(now())
  endDate   DateTime
  createdAt DateTime @default(now())

  post   Post @relation(fields: [postId], references: [id], onDelete: Cascade)
  postId String
  user   User @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId String

  @@index([postId])
  @@index([userId])
  @@index([status, endDate])
}

model Banner {
  id             String   @id @default(cuid())
  title          String
  imageUrl       String
  linkUrl        String
  position       String   @default("both") // feed | gallery | both
  targetCategory String   @default("all") // all | kitchens | wardrobes | tables | shelves | sofas | beds | hardware | materials
  bannerType     String   @default("standard") // standard | panorama | mini
  images         String   @default("[]") // JSON массив URL для панорамы (5 фото)
  status         String   @default("pending") // pending | active | expired
  startDate      DateTime @default(now())
  endDate        DateTime
  createdAt      DateTime @default(now())

  user   User @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId String

  @@index([status, position])
  @@index([userId])
}

model Subscription {
  id            String    @id @default(cuid())
  plan          String    // "lite" | "pro" | "premium"
  period        String    // "monthly" | "yearly"
  status        String    @default("pending") // pending | active | expired | cancelled
  startDate     DateTime?
  endDate       DateTime?
  createdAt     DateTime  @default(now())

  user          User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId        String

  @@index([userId])
  @@index([status])
}

model PushSubscription {
  id           String   @id @default(cuid())
  endpoint     String
  p256dh       String
  auth         String
  createdAt    DateTime @default(now())

  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId       String

  @@unique([endpoint])
  @@index([userId])
}

model Feedback {
  id        String   @id @default(cuid())
  type      String   // "bug" | "feature"
  message   String
  ip        String?
  createdAt DateTime @default(now())

  user   User?  @relation(fields: [userId], references: [id], onDelete: SetNull)
  userId String?

  @@index([userId])
  @@index([createdAt])
}

model ActivityLog {
  id        String   @id @default(cuid())
  action    String   // "login" | "register" | "post_create" | "comment" | "follow" | "ban" | "role_change" | "feedback" | etc.
  details   String?
  ip        String?
  createdAt DateTime @default(now())

  user   User?  @relation(fields: [userId], references: [id], onDelete: SetNull)
  userId String?

  @@index([userId])
  @@index([action])
  @@index([createdAt])
}

model AdminAlert {
  id        String   @id @default(cuid())
  type      String
  title     String
  read      Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([type, read])
  @@index([createdAt])
}

model UserSectionView {
  id         String   @id @default(cuid())
  userId     String
  section    String
  lastViewed DateTime @default(now())

  @@unique([userId, section])
  @@index([userId])
}
